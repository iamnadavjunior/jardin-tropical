# ── Set these in the Hostinger environment variables panel ──────────────────

# MySQL password (shared between the app and the DB container)
DB_PASSWORD="your-secure-db-password"

# MySQL root password (used by the DB container only)
DB_ROOT_PASSWORD="your-secure-root-password"

# Auth secret — generate with: openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_WITH_A_LONG_RANDOM_SECRET"

# Public URL of your site (no trailing slash)
NEXTAUTH_URL="https://yourdomain.com"

# First admin credentials (used on first boot / seed)
ADMIN_EMAIL="admin@jardintropical.com"
ADMIN_PASSWORD="CHANGE_ME"